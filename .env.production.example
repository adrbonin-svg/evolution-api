# ══════════════════════════════════════════════════════════
# AutoPrime Tech — Evolution API Production Config
# Copie para .env e preencha os valores
# ══════════════════════════════════════════════════════════

# ── Servidor ──────────────────────────────────────────────
SERVER_NAME=autoprimetech-evolution
SERVER_TYPE=http
SERVER_PORT=8080
SERVER_URL=https://crm.autoprimetech.com.br

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGIN=https://crm.autoprimetech.com.br
CORS_METHODS=GET,POST,PUT,DELETE
CORS_CREDENTIALS=true

# ── Logs ──────────────────────────────────────────────────
LOG_LEVEL=ERROR,WARN,INFO,LOG
LOG_COLOR=false
LOG_BAILEYS=error

# ── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=evolution
POSTGRES_PASSWORD=SENHA_FORTE_AQUI           # ← gere com: openssl rand -base64 32
POSTGRES_DB=evolution_db

DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgresql://evolution:SENHA_FORTE_AQUI@postgres:5432/evolution_db?schema=evolution_api
DATABASE_CONNECTION_CLIENT_NAME=autoprimetech_evolution

DATABASE_SAVE_DATA_INSTANCE=true
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=true
DATABASE_SAVE_DATA_CONTACTS=true
DATABASE_SAVE_DATA_CHATS=true
DATABASE_SAVE_DATA_LABELS=true
DATABASE_SAVE_DATA_HISTORIC=true
DATABASE_SAVE_IS_ON_WHATSAPP=true
DATABASE_SAVE_IS_ON_WHATSAPP_DAYS=7
DATABASE_DELETE_MESSAGE=true

# ── Redis ─────────────────────────────────────────────────
REDIS_PASSWORD=SENHA_REDIS_AQUI              # ← gere com: openssl rand -base64 16
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://:SENHA_REDIS_AQUI@redis:6379/0
CACHE_REDIS_TTL=604800
CACHE_REDIS_PREFIX_KEY=autoprimetech
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false

# ── Autenticação ──────────────────────────────────────────
AUTHENTICATION_API_KEY=CHAVE_MESTRA_AQUI     # ← gere com: openssl rand -hex 32
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true

# ── QR Code ───────────────────────────────────────────────
QRCODE_LIMIT=30
QRCODE_COLOR=#175197

# ── WhatsApp Session ──────────────────────────────────────
CONFIG_SESSION_PHONE_CLIENT=AutoPrime Tech
CONFIG_SESSION_PHONE_NAME=Chrome

# ── Webhook Global ────────────────────────────────────────
WEBHOOK_GLOBAL_ENABLED=false
WEBHOOK_EVENTS_APPLICATION_STARTUP=false
WEBHOOK_EVENTS_QRCODE_UPDATED=true
WEBHOOK_EVENTS_MESSAGES_UPSERT=true
WEBHOOK_EVENTS_MESSAGES_UPDATE=true
WEBHOOK_EVENTS_CONNECTION_UPDATE=true
WEBHOOK_EVENTS_CONTACTS_UPSERT=true
WEBHOOK_REQUEST_TIMEOUT_MS=30000
WEBHOOK_RETRY_MAX_ATTEMPTS=5

# ── Idioma ────────────────────────────────────────────────
LANGUAGE=pt-BR

# ── Telemetria (desativar em produção se desejar) ─────────
TELEMETRY_ENABLED=false

# ── Integrações Opcionais ─────────────────────────────────
TYPEBOT_ENABLED=false
CHATWOOT_ENABLED=false
OPENAI_ENABLED=false
N8N_ENABLED=false
RABBITMQ_ENABLED=false
SQS_ENABLED=false
WEBSOCKET_ENABLED=true
WEBSOCKET_GLOBAL_EVENTS=false

# ── Monitoramento ─────────────────────────────────────────
PROMETHEUS_METRICS=false
SENTRY_DSN=
